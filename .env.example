# Solver Poker — variables de entorno
# Copia este archivo como .env y ajusta los valores

# Interfaz de red en la que escucha el servidor (por defecto 127.0.0.1)
HOST=127.0.0.1

# Puerto del servidor HTTP (por defecto 3000)
PORT=3000

# Entorno de ejecucion: development | production
NODE_ENV=development

# Origenes permitidos para CORS, separados por coma. En desarrollo puede ser "*".
CORS_ORIGIN=*

# Limites de peticiones por minuto
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_POKER_MAX_REQUESTS=40
